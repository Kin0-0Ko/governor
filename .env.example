DB_HOST=localhost
DB_PORT=5432
# Superuser creds — used only for running migrations (CREATE ROLE etc.)
DB_USER=governor
DB_PASS=governor_dev
DB_NAME=governor

# Runtime app/worker login — least-privilege role granted `api_role`
# (created by migration 005_api_role_grant.ts); spend_events append-only
# revoke only takes effect at runtime when connected as this role.
DB_APP_USER=governor_api
DB_APP_PASS=governor_dev

REDIS_CLUSTER_NODES=localhost:7000,localhost:7001,localhost:7002,localhost:7003,localhost:7004,localhost:7005

RABBITMQ_URL=amqp://governor:governor_dev@localhost:5672
PORT=3000
CORS_ORIGIN=http://localhost:4200
