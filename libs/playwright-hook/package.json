{
  "name": "@scrape-governor/playwright-hook",
  "version": "0.1.0",
  "description": "Playwright request interceptor with atomic budget enforcement via Governor API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kin0-0Ko/governor.git",
    "directory": "libs/playwright-hook"
  },
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "!src/**/*.spec.*",
    "!src/**/__tests__"
  ],
  "dependencies": {
    "tslib": "^2.6.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0",
