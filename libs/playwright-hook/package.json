  },
  "peerDependenciesMeta": {
    "@playwright/test": { "optional": true },
    "playwright": { "optional": true }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": ["playwright", "budget", "cost-control", "scraping", "governor"]
