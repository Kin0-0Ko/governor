{
  "name": "worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/worker/src",
  "projectType": "application",
  "tags": ["scope:worker"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/worker"],
      "options": {
        "command": "tsc -p apps/worker/tsconfig.app.json --outDir dist/apps/worker"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cross-env TS_NODE_PROJECT=apps/worker/tsconfig.app.json ts-node -r tsconfig-paths/register apps/worker/src/main.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/worker/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/worker"],
      "options": {
        "jestConfig": "apps/worker/jest.config.ts"
      }
    }
  }
}
